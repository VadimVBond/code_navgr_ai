{
  "name": "ai-project-os",
  "displayName": "AI Project OS",
  "description": "Project Intelligence Layer for VS Code",
  "version": "0.0.1",
  "publisher": "code-navgr",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-project-os.openPanel",
        "title": "AI Project OS: Open Panel"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3",
    "eslint": "^8.41.0",
    "@typescript-eslint/parser": "^5.59.8",
    "@typescript-eslint/eslint-plugin": "^5.59.8"
  }
}
